      "message": {
        "role": "system",
        "content": "You are an agentic coding assistant. Keep generated artifacts as files."
      }
    },
    {
      "id": "msg_002",
      "created_at": "2026-04-27T10:00:12Z",
      "message": {
        "role": "user",
        "content": "Create a short Markdown report and save it as report.md."
      }
    },
    {
      "id": "msg_003",
      "created_at": "2026-04-27T10:00:20Z",
      "model": "claude-sonnet-4-6",
      "toolset_id": "tools_fs_v1",
      "message": {
        "role": "assistant",
        "content": [
          {
            "type": "text",
            "text": "I'll write the report file now."
          }
        ],
        "tool_calls": [
          {
            "id": "call_write_001",
            "type": "function",
            "function": {
              "name": "write_file",
              "arguments": "{\"path\":\"report.md\",\"content\":\"# Report\\n\\nInitial draft.\"}"
            }
          }
        ]
      }
    },
    {
      "id": "msg_004",
      "created_at": "2026-04-27T10:00:22Z",
      "status": "ok",
      "message": {
        "role": "tool",
        "tool_call_id": "call_write_001",
        "content": "Wrote 128 bytes to report.md"
      }
    },
    {
      "id": "msg_005",
      "created_at": "2026-04-27T10:01:00Z",
      "model": "claude-sonnet-4-6",
      "toolset_id": "tools_fs_v1",
      "message": {
        "role": "assistant",
        "content": [
          {
            "type": "text",
            "text": "I'll try to overwrite it with the final version."
          }
        ],
        "tool_calls": [
          {
            "id": "call_write_002",
            "type": "function",
            "function": {
              "name": "write_file",
              "arguments": "{\"path\":\"report.md\",\"content\":\"# Report\\n\\nFinal version with details.\"}"
            }
          }
        ]
      }
    },
    {
      "id": "msg_006",
      "created_at": "2026-04-27T10:01:05Z",
      "status": "error",
      "message": {
